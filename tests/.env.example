# EasyUniVPN integration test credentials
# Copy this file to .env and fill in your real university credentials.
# The test suite needs both good credentials (to verify setup works)
# and bad ones (to verify credential rejection is detected fast).
#
# NEVER commit .env to version control - it contains your real password.
# .env is already listed in .gitignore.

# Your real university credentials (must actually work for auth tests to pass)
GOOD_EMAIL=yourname@edu.uni-graz.at
GOOD_PASSWORD=YourRealPassword
GOOD_TOTP=YOUR_BASE32_TOTP_SECRET

# Credentials that should be rejected by the Graz SSO
BAD_EMAIL=doesnotexist@edu.uni-graz.at
BAD_PASSWORD=DefinitelyWrongPassword123!
# BAD_TOTP must be valid base32 format (16+ chars) but generate wrong codes
BAD_TOTP=AAAAAAAAAAAAAAAA
